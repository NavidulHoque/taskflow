# Server
NODE_ENV=development
PORT=3000

# Supabase — find these in your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# Database — find this in Supabase project settings > Database > Connection string
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# CORS — comma-separated allowed origins; defaults to * in dev, blocked in prod
CORS_ORIGIN=
