{
	"$schema": "https://turbo.build/schema.json",
	"envMode": "loose",
	"globalDependencies": ["**/.env", "**/.env.*"],
	"globalEnv": ["NODE_ENV"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"lint": {},
		"clean": {
			"cache": false
		}
	}
}
