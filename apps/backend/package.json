{
	"name": "@taskflow/backend",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "nest start --watch",
		"build": "nest build",
		"test": "jest",
		"typecheck": "tsc --noEmit",
		"lint": "eslint src",
		"clean": "bunx rimraf node_modules .turbo dist *.tsbuildinfo"
	},
	"dependencies": {
		"@fastify/cors": "11.2.0",
		"@fastify/helmet": "13.0.2",
		"@fastify/rate-limit": "10.2.2",
		"@nestjs/common": "11.1.17",
		"@nestjs/config": "4.0.3",
		"@nestjs/core": "11.1.17",
		"@nestjs/platform-fastify": "11.1.17",
		"@orpc/openapi": "1.13.14",
		"@orpc/zod": "1.13.14",
		"@taskflow/database": "workspace:*",
		"@taskflow/orpc": "workspace:*",
		"@taskflow/shared": "workspace:*",
		"@taskflow/supabase": "workspace:*",
		"@taskflow/validation": "workspace:*",
		"fastify": "5.8.4",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@nestjs/cli": "11.0.16",
		"@nestjs/schematics": "11.0.9",
		"@nestjs/testing": "11.1.17",
		"@types/jest": "29.5.12",
		"@types/node": "25.5.0",
		"jest": "30.3.0",
		"pino-pretty": "13.1.3",
		"rimraf": "6.1.3",
		"ts-jest": "29.4.6",
		"ts-loader": "9.5.7",
		"ts-node": "10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "5.9.3"
	},
	"jest": {
		"moduleFileExtensions": ["ts", "js", "json"],
		"rootDir": ".",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.ts$": "ts-jest"
		},
		"collectCoverageFrom": ["src/**/*.(t|j)s"],
		"coverageDirectory": "./coverage",
		"testEnvironment": "node",
		"roots": ["<rootDir>/src/"],
		"moduleNameMapper": {
			"^@backend/libs/(.*)$": "<rootDir>/libs/$1",
			"^@backend/(.*)$": "<rootDir>/src/$1",
			"^@taskflow/database$": "<rootDir>/../../packages/database/src/index.ts",
			"^@taskflow/orpc$": "<rootDir>/test/mocks/orpc.js",
			"^@taskflow/shared$": "<rootDir>/../../packages/shared/src",
			"^@taskflow/validation$": "<rootDir>/../../packages/validation/src",
			"^@taskflow/supabase$": "<rootDir>/../../packages/supabase/src"
		}
	}
}
